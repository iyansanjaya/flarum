# ============================
# Flarum Docker - Environment
# ============================
# Salin file ini menjadi .env lalu isi dengan nilai Anda sendiri:
#   cp .env.example .env

# --- Database ---
MYSQL_ROOT_PASSWORD=ganti_dengan_password_root_yang_kuat
MYSQL_DATABASE=flarum
MYSQL_USER=flarum
MYSQL_PASSWORD=ganti_dengan_password_user_yang_kuat

