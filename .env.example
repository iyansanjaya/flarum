# ============================
# Flarum Docker - Environment
# ============================
# Copy this file to .env and fill in your own values:
#   cp .env.example .env

# --- Database ---
# Superadmin password (for maintenance/backup only, do NOT use for Flarum)
MYSQL_ROOT_PASSWORD=replace_with_a_strong_root_password

MYSQL_DATABASE=flarum
MYSQL_USER=flarum

# Flarum database password (use THIS one in the Flarum web installer)
MYSQL_PASSWORD=replace_with_a_strong_user_password

# --- FoF Upload - S3 Storage (Optional) ---
# Leave empty if not using S3. Fill in to enable S3 file uploads.
# Required (all 4 must be set)
FOF_UPLOAD_AWS_S3_KEY=
FOF_UPLOAD_AWS_S3_SECRET=
FOF_UPLOAD_AWS_S3_BUCKET=
FOF_UPLOAD_AWS_S3_REGION=

# Optional
FOF_UPLOAD_AWS_S3_ACL=
FOF_UPLOAD_AWS_S3_ENDPOINT=
FOF_UPLOAD_AWS_S3_PATH_STYLE_ENDPOINT=
FOF_UPLOAD_AWS_S3_CUSTOM_URL=
FOF_UPLOAD_CDN_URL=
